---
import ToolLogo from './ToolLogo.astro';

interface Tool {
  slug: string;
  name: string;
  category: string;
  website: string;
  pricing: { model: string; details: string };
  attributes: {
    openSource: boolean;
    auditedThirdParty: boolean;
    noLogsPolicy: boolean;
    anonymousSignup: boolean;
    e2eEncrypted: boolean;
    selfHostable: boolean;
    mobileSupport: boolean;
    desktopSupport: boolean;
  };
  scores: { privacy: number; security: number; usability: number };
  tags: string[];
  description: string;
}

interface Props {
  tool: Tool;
}

const { tool: d } = Astro.props;

function scoreClass(n: number) {
  if (n >= 8) return 'score--high';
  if (n >= 6) return 'score--mid';
  return 'score--low';
}

const catBgs: Record<string, string> = {
  vpn: 'var(--cat-vpn-light)',
  browser: 'var(--cat-browser-light)',
  email: 'var(--cat-email-light)',
  messaging: 'var(--cat-messaging-light)',
  dns: 'var(--cat-dns-light)',
  os: 'var(--cat-os-light)',
  search: 'var(--cat-search-light)',
};
const catBg = catBgs[d.category] ?? 'var(--clr-accent-subtle)';

const tags: { label: string; variant: string }[] = [];
if (d.attributes.openSource)
  tags.push({ label: 'Open Source', variant: 'good' });
if (d.attributes.auditedThirdParty)
  tags.push({ label: 'Audited', variant: 'good' });
if (d.attributes.noLogsPolicy) tags.push({ label: 'No Logs', variant: 'good' });
if (d.attributes.e2eEncrypted) tags.push({ label: 'E2E', variant: 'good' });
if (d.attributes.anonymousSignup)
  tags.push({ label: 'Anon Signup', variant: 'info' });
if (d.attributes.selfHostable)
  tags.push({ label: 'Self-Host', variant: 'info' });
if (!d.attributes.mobileSupport)
  tags.push({ label: 'No Mobile', variant: 'warn' });
if (d.pricing.model === 'free' || d.pricing.model === 'open-source') {
  tags.push({ label: 'Free', variant: 'good' });
}
---

<div
  class="tool-card"
  data-pricing={d.pricing.model}
  data-oss={String(d.attributes.openSource)}
  data-audited={String(d.attributes.auditedThirdParty)}
  data-mobile={String(d.attributes.mobileSupport)}
>
  <div class="tool-card__logo">
    <ToolLogo slug={d.slug} name={d.name} category={d.category} size={24} />
  </div>

  <div class="tool-card__body">
    <div class="tool-card__top">
      <a href={`/tool/${d.slug}`} class="tool-card__name">{d.name}</a>
      <span class={`pricing-badge pricing-badge--${d.pricing.model}`}
        >{d.pricing.model}</span
      >
    </div>

    <div class="tool-card__tags">
      {
        tags
          .slice(0, 6)
          .map((t) => (
            <span class={`tool-tag tool-tag--${t.variant}`}>{t.label}</span>
          ))
      }
    </div>

    <p class="tool-card__desc">{d.description}</p>

    <div class="tool-card__footer">
      <div class="tool-card__scores">
        <span class="tool-card__score-item" title="Privacy score">
          <i
            class="fa-solid fa-user-shield"
            style="font-size: 0.625rem; color: var(--clr-muted-light);"
            aria-hidden="true"></i>
          <span class={`score ${scoreClass(d.scores.privacy)}`}
            >{d.scores.privacy.toFixed(1)}</span
          >
        </span>
        <span class="tool-card__score-item" title="Security score">
          <i
            class="fa-solid fa-lock"
            style="font-size: 0.625rem; color: var(--clr-muted-light);"
            aria-hidden="true"></i>
          <span class={`score ${scoreClass(d.scores.security)}`}
            >{d.scores.security.toFixed(1)}</span
          >
        </span>
        <span class="tool-card__score-item" title="Usability score">
          <i
            class="fa-solid fa-star"
            style="font-size: 0.625rem; color: var(--clr-muted-light);"
            aria-hidden="true"></i>
          <span class={`score ${scoreClass(d.scores.usability)}`}
            >{d.scores.usability.toFixed(1)}</span
          >
        </span>
      </div>
      <a
        href={`/tool/${d.slug}`}
        class="tool-card__link"
        aria-label={`View ${d.name} details`}
      >
        Details <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
    </div>
  </div>
</div>
