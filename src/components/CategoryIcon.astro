---
interface Props {
  category: string;
  size?: number;
  class?: string;
}
const { category, size = 14, class: cls = '' } = Astro.props;

const iconMap: Record<string, string> = {
  vpn: 'fa-solid fa-shield-halved',
  browser: 'fa-solid fa-globe',
  email: 'fa-solid fa-envelope',
  messaging: 'fa-solid fa-comments',
  dns: 'fa-solid fa-server',
  os: 'fa-solid fa-laptop-code',
  search: 'fa-solid fa-magnifying-glass',
};

const icon = iconMap[category] ?? 'fa-solid fa-circle';
---

<i
  class={`${icon} ${cls}`}
  style={`font-size: ${size}px; line-height: 1;`}
  aria-hidden="true"></i>
