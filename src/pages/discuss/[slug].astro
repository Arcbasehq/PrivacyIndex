---
import Layout from '../../layouts/Layout.astro';
import { getThread, getPosts, initSchema } from '../../lib/db';

const { slug } = Astro.params;
await initSchema();
const thread = await getThread(slug!);
if (!thread) return Astro.redirect('/discuss');

const posts = await getPosts(thread.id);

const auth = Astro.locals.auth();
const isLoggedIn = !!auth.userId;
const currentUserId = auth.userId ?? null;
const isThreadAuthor = currentUserId === thread.author_id;

const categories: Record<
  string,
  { label: string; color: string; icon: string }
> = {
  general: { label: 'General', color: '#8b929e', icon: 'fa-comments' },
  vpn: { label: 'VPN', color: '#2dd4bf', icon: 'fa-shield-halved' },
  browsers: { label: 'Browsers', color: '#60a5fa', icon: 'fa-globe' },
  email: { label: 'Email', color: '#f87171', icon: 'fa-envelope' },
  messaging: { label: 'Messaging', color: '#34d399', icon: 'fa-message' },
  os: { label: 'OS & Devices', color: '#94a3b8', icon: 'fa-laptop-code' },
  threat_model: {
    label: 'Threat Model',
    color: '#a78bfa',
    icon: 'fa-user-shield',
  },
  tools: { label: 'Tools', color: '#fb923c', icon: 'fa-screwdriver-wrench' },
};

const cat = categories[thread.category] ?? categories.general;

function timeAgo(date: string) {
  const s = Math.floor((Date.now() - new Date(date).getTime()) / 1000);
  if (s < 60) return 'just now';
  if (s < 3600) return `${Math.floor(s / 60)}m ago`;
  if (s < 86400) return `${Math.floor(s / 3600)}h ago`;
  return `${Math.floor(s / 86400)}d ago`;
}

function initials(name: string) {
  return name
    .split(' ')
    .map((n) => n[0])
    .join('')
    .slice(0, 2)
    .toUpperCase();
}
---

<Layout title={`${thread.title} — Discuss`}>
  <div class="main-content">
    <!-- Breadcrumb -->
    <div class="td-breadcrumb">
      <a href="/discuss">Discuss</a>
      <i class="fa-solid fa-chevron-right"></i>
      <span class="td-breadcrumb__cat" style={`color: ${cat.color}`}>
        <i class={`fa-solid ${cat.icon}`}></i>
        {cat.label}
      </span>
    </div>

    <!-- Thread OP -->
    <div class="td-thread" id="thread-block">
      <div class="td-thread__header">
        <h1 class="td-thread__title" id="thread-title-display">
          {thread.title}
        </h1>
        {
          isThreadAuthor && (
            <div class="td-manage-btns">
              <button
                class="td-manage-btn"
                id="edit-thread-btn"
                title="Edit thread"
              >
                <i class="fa-solid fa-pen" />
              </button>
              <button
                class="td-manage-btn td-manage-btn--danger"
                id="delete-thread-btn"
                title="Delete thread"
                data-id={thread.id}
              >
                <i class="fa-solid fa-trash" />
              </button>
            </div>
          )
        }
      </div>

      <div class="td-thread__meta">
        {
          thread.author_avatar ? (
            <img src={thread.author_avatar} class="td-avatar" alt="" />
          ) : (
            <div class="td-avatar td-avatar--init">
              {initials(thread.author_name)}
            </div>
          )
        }
        <span class="td-thread__author">{thread.author_name}</span>
        <span class="td-meta-dot">·</span>
        <span>{timeAgo(thread.created_at)}</span>
        <span class="td-meta-dot">·</span>
        <span class="td-cat-pill" style={`color: ${cat.color}`}
          >{cat.label}</span
        >
      </div>

      <!-- View mode -->
      <div class="td-thread__body" id="thread-body-display">{thread.body}</div>
    </div>

    <!-- Replies -->
    {
      posts.length > 0 && (
        <div class="td-replies">
          <div class="td-replies__header">
            <i class="fa-solid fa-reply" />
            {posts.length} {posts.length === 1 ? 'reply' : 'replies'}
          </div>
          {posts.map((p: any) => {
            const isPostAuthor = currentUserId === p.author_id;
            return (
              <div class="td-post" id={`post-${p.id}`}>
                <div class="td-post__header">
                  <div class="td-post__author">
                    {p.author_avatar ? (
                      <img src={p.author_avatar} class="td-avatar" alt="" />
                    ) : (
                      <div class="td-avatar td-avatar--init">
                        {initials(p.author_name)}
                      </div>
                    )}
                    <span class="td-post__name">{p.author_name}</span>
                    <span class="td-meta-dot">·</span>
                    <span class="td-post__time">{timeAgo(p.created_at)}</span>
                  </div>
                  {isPostAuthor && (
                    <div class="td-manage-btns">
                      <button
                        class="td-manage-btn"
                        onclick={`editPost(${p.id})`}
                        title="Edit reply"
                      >
                        <i class="fa-solid fa-pen" />
                      </button>
                      <button
                        class="td-manage-btn td-manage-btn--danger"
                        onclick={`deletePost(${p.id})`}
                        title="Delete reply"
                      >
                        <i class="fa-solid fa-trash" />
                      </button>
                    </div>
                  )}
                </div>
                <div class="td-post__body" id={`post-body-${p.id}`}>
                  {p.body}
                </div>
              </div>
            );
          })}
        </div>
      )
    }

    <!-- Reply box -->
    {
      isLoggedIn ? (
        <div class="td-reply-box">
          <div class="td-reply-box__header">Add a reply</div>
          <form id="reply-form">
            <textarea
              class="td-reply-input"
              id="reply-body"
              placeholder="Share your thoughts..."
              rows={4}
              required
            />
            <div class="td-reply-actions">
              <button type="submit" class="td-reply-btn" id="reply-btn">
                <i class="fa-solid fa-paper-plane" /> Reply
              </button>
            </div>
            <div
              class="td-reply-error"
              id="reply-error"
              style="display:none;"
            />
          </form>
        </div>
      ) : (
        <div class="td-signin-prompt">
          <a href="/sign-in">Sign in</a> to join the discussion.
        </div>
      )
    }
  </div>
  <!-- ── Edit thread modal ── -->
  {
    isThreadAuthor && (
      <div class="td-modal-backdrop" id="thread-modal" aria-hidden="true">
        <div class="td-modal" role="dialog">
          <div class="td-modal__hd">
            <span>
              <i class="fa-solid fa-pen" /> Edit thread
            </span>
            <button class="td-modal__close" id="cancel-thread-btn">
              <i class="fa-solid fa-xmark" />
            </button>
          </div>
          <div class="td-modal__body">
            <label class="td-modal__label">Title</label>
            <input
              class="td-modal__input"
              id="edit-title-input"
              type="text"
              value={thread.title}
            />
            <label class="td-modal__label">Body</label>
            <textarea class="td-modal__textarea" id="edit-body-input" rows={8}>
              {thread.body}
            </textarea>
          </div>
          <div class="td-modal__ft">
            <button
              class="td-modal__btn td-modal__btn--cancel"
              id="cancel-thread-btn2"
            >
              Cancel
            </button>
            <button
              class="td-modal__btn td-modal__btn--save"
              id="save-thread-btn"
              data-id={thread.id}
            >
              <i class="fa-solid fa-check" /> Save changes
            </button>
          </div>
        </div>
      </div>
    )
  }

  <!-- ── Edit reply modal ── -->
  <div class="td-modal-backdrop" id="post-modal" aria-hidden="true">
    <div class="td-modal" role="dialog">
      <div class="td-modal__hd">
        <span><i class="fa-solid fa-pen"></i> Edit reply</span>
        <button class="td-modal__close" id="cancel-post-btn">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <div class="td-modal__body">
        <textarea class="td-modal__textarea" id="post-modal-textarea" rows={8}
        ></textarea>
      </div>
      <div class="td-modal__ft">
        <button
          class="td-modal__btn td-modal__btn--cancel"
          id="cancel-post-btn2">Cancel</button
        >
        <button class="td-modal__btn td-modal__btn--save" id="save-post-btn">
          <i class="fa-solid fa-check"></i> Save changes
        </button>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ slug, threadId: thread.id }}>
  /* ── Reply ── */
  const replyForm = document.getElementById('reply-form');
  if (replyForm) {
    const btn = document.getElementById('reply-btn');
    const errEl = document.getElementById('reply-error');
    replyForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Posting…';
      errEl.style.display = 'none';
      const body = document.getElementById('reply-body').value;
      try {
        const res = await fetch('/api/discuss/reply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ threadSlug: slug, body }),
        });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error ?? 'Failed');
        location.reload();
      } catch (err) {
        errEl.textContent = err.message;
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-paper-plane"></i> Reply';
      }
    });
  }

  /* ── Edit thread modal ── */
  const threadModal = document.getElementById('thread-modal');

  function openThreadModal() {
    threadModal.setAttribute('aria-hidden', 'false');
    threadModal.style.display = 'flex';
    document.getElementById('edit-title-input')?.focus();
  }
  function closeThreadModal() {
    threadModal.setAttribute('aria-hidden', 'true');
    threadModal.style.display = 'none';
  }

  document
    .getElementById('edit-thread-btn')
    ?.addEventListener('click', openThreadModal);
  document
    .getElementById('cancel-thread-btn')
    ?.addEventListener('click', closeThreadModal);
  document
    .getElementById('cancel-thread-btn2')
    ?.addEventListener('click', closeThreadModal);
  threadModal?.addEventListener('click', (e) => {
    if (e.target === threadModal) closeThreadModal();
  });

  document
    .getElementById('save-thread-btn')
    ?.addEventListener('click', async () => {
      const btn = document.getElementById('save-thread-btn');
      const id = btn.dataset.id;
      const title = document.getElementById('edit-title-input').value.trim();
      const body = document.getElementById('edit-body-input').value.trim();
      if (!title || !body) return;
      btn.textContent = 'Saving…';
      btn.disabled = true;
      const res = await fetch(`/api/discuss/thread/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, body }),
      });
      if (res.ok) {
        location.reload();
      } else {
        const j = await res.json();
        alert(j.error ?? 'Failed to save');
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Save changes';
      }
    });

  /* ── Delete thread ── */
  document
    .getElementById('delete-thread-btn')
    ?.addEventListener('click', async () => {
      if (
        !confirm('Delete this thread and all replies? This cannot be undone.')
      )
        return;
      const id = document.getElementById('delete-thread-btn').dataset.id;
      const res = await fetch(`/api/discuss/thread/${id}`, {
        method: 'DELETE',
      });
      if (res.ok) {
        location.href = '/discuss';
      } else {
        const j = await res.json();
        alert(j.error ?? 'Failed to delete');
      }
    });

  /* ── Edit / delete post (reply) via modal ── */
  const postModal = document.getElementById('post-modal');
  let editingPostId = null;

  function openPostModal(id) {
    editingPostId = id;
    const body = document.getElementById(`post-body-${id}`)?.textContent ?? '';
    document.getElementById('post-modal-textarea').value = body.trim();
    postModal.setAttribute('aria-hidden', 'false');
    postModal.style.display = 'flex';
    document.getElementById('post-modal-textarea')?.focus();
  }
  function closePostModal() {
    postModal.setAttribute('aria-hidden', 'true');
    postModal.style.display = 'none';
    editingPostId = null;
  }

  document
    .getElementById('cancel-post-btn')
    ?.addEventListener('click', closePostModal);
  document
    .getElementById('cancel-post-btn2')
    ?.addEventListener('click', closePostModal);
  postModal?.addEventListener('click', (e) => {
    if (e.target === postModal) closePostModal();
  });

  document
    .getElementById('save-post-btn')
    ?.addEventListener('click', async () => {
      if (!editingPostId) return;
      const btn = document.getElementById('save-post-btn');
      const body = document.getElementById('post-modal-textarea').value.trim();
      if (!body) return;
      btn.textContent = 'Saving…';
      btn.disabled = true;
      const res = await fetch(`/api/discuss/post/${editingPostId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body }),
      });
      if (res.ok) {
        location.reload();
      } else {
        const j = await res.json();
        alert(j.error ?? 'Failed to save');
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Save changes';
      }
    });

  window.editPost = (id) => openPostModal(id);

  window.deletePost = async (id) => {
    if (!confirm('Delete this reply?')) return;
    const res = await fetch(`/api/discuss/post/${id}`, { method: 'DELETE' });
    if (res.ok) {
      location.reload();
    } else {
      const j = await res.json();
      alert(j.error ?? 'Failed to delete');
    }
  };
</script>

<style>
  .td-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--clr-muted);
    margin-bottom: 1.25rem;
  }
  .td-breadcrumb a {
    color: var(--clr-muted);
    text-decoration: none;
  }
  .td-breadcrumb a:hover {
    color: var(--clr-text-secondary);
  }
  .td-breadcrumb i {
    font-size: 0.5rem;
  }
  .td-breadcrumb__cat {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-weight: 600;
  }

  .td-thread {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .td-thread__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .td-thread__title {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--clr-text);
    line-height: 1.3;
    flex: 1;
  }

  .td-manage-btns {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .td-manage-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--clr-border-strong);
    background: var(--clr-surface-alt);
    color: var(--clr-muted);
    font-size: 0.6875rem;
    cursor: pointer;
    transition: all 0.1s;
  }
  .td-manage-btn:hover {
    color: var(--clr-text);
    border-color: var(--clr-border-strong);
  }
  .td-manage-btn--danger:hover {
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.3);
    background: rgba(248, 113, 113, 0.08);
  }

  .td-thread__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--clr-muted);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .td-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .td-avatar--init {
    background: var(--clr-surface-alt);
    border: 1px solid var(--clr-border-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.5625rem;
    font-weight: 700;
    color: var(--clr-muted);
  }

  .td-thread__author {
    font-weight: 600;
    color: var(--clr-text-secondary);
  }
  .td-meta-dot {
    opacity: 0.4;
  }
  .td-cat-pill {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .td-thread__body {
    font-size: 0.9rem;
    color: var(--clr-text-secondary);
    line-height: 1.75;
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* ── Modals ── */
  .td-modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .td-modal {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border-strong);
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
    width: 100%;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: modal-in 0.15s ease;
  }
  @keyframes modal-in {
    from {
      opacity: 0;
      transform: translateY(8px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .td-modal__hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--clr-border);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--clr-text);
  }
  .td-modal__hd i {
    color: var(--clr-muted);
    margin-right: 0.25rem;
  }

  .td-modal__close {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--clr-border);
    background: var(--clr-surface-alt);
    color: var(--clr-muted);
    font-size: 0.75rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    padding: 0;
    transition: all 0.1s;
  }
  .td-modal__close:hover {
    color: var(--clr-text);
    border-color: var(--clr-border-strong);
  }

  .td-modal__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .td-modal__label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--clr-muted);
  }

  .td-modal__input {
    width: 100%;
    background: var(--clr-bg-alt);
    border: 1px solid var(--clr-border-strong);
    border-radius: var(--radius-sm);
    color: var(--clr-text);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.625rem 0.875rem;
    transition: border-color 0.1s;
  }
  .td-modal__input:focus {
    outline: none;
    border-color: #5c6bc0;
  }

  .td-modal__textarea {
    width: 100%;
    background: var(--clr-bg-alt);
    border: 1px solid var(--clr-border-strong);
    border-radius: var(--radius-sm);
    color: var(--clr-text);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.7;
    padding: 0.625rem 0.875rem;
    resize: vertical;
    transition: border-color 0.1s;
  }
  .td-modal__textarea:focus {
    outline: none;
    border-color: #5c6bc0;
  }

  .td-modal__ft {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.5rem;
    padding: 0.875rem 1.25rem;
    border-top: 1px solid var(--clr-border);
    background: var(--clr-bg-alt);
  }

  .td-modal__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.45rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: all 0.1s;
  }
  .td-modal__btn--save {
    background: #5c6bc0;
    color: #fff;
    border-color: #5c6bc0;
  }
  .td-modal__btn--save:hover {
    background: #4a59b0;
  }
  .td-modal__btn--save:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .td-modal__btn--cancel {
    background: var(--clr-surface-alt);
    color: var(--clr-muted);
    border-color: var(--clr-border-strong);
  }
  .td-modal__btn--cancel:hover {
    color: var(--clr-text);
  }

  /* ── Replies ── */
  .td-replies {
    background: var(--clr-surface);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .td-replies__header {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--clr-muted);
    padding: 0.625rem 1rem;
    border-bottom: 1px solid var(--clr-border);
    background: var(--clr-bg-alt);
  }
  .td-post {
    padding: 1rem;
    border-bottom: 1px solid var(--clr-border);
  }
  .td-post:last-child {
    border-bottom: none;
  }

  .td-post__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .td-post__author {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--clr-muted);
  }
  .td-post__name {
    font-weight: 600;
    color: var(--clr-text-secondary);
  }
  .td-post__time {
    color: var(--clr-muted);
  }
  .td-post__body {
    font-size: 0.875rem;
    color: var(--clr-text-secondary);
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .td-post__edit {
    margin-top: 0.5rem;
  }

  /* ── Reply box ── */
  .td-reply-box {
