---
import Layout from '../../layouts/Layout.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import ToolLogo from '../../components/ToolLogo.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map((tool) => ({
    params: { slug: tool.data.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const d = tool.data;

const allTools = await getCollection('tools');
const alternatives = allTools
  .filter((t) => t.data.category === d.category && t.data.slug !== d.slug)
  .sort((a, b) => b.data.scores.privacy - a.data.scores.privacy)
  .slice(0, 4);

const categoryLabels: Record<string, string> = {
  vpn: 'VPN Services',
  browser: 'Web Browsers',
  email: 'Email Providers',
  messaging: 'Messaging Apps',
  dns: 'DNS Resolvers',
  os: 'Operating Systems',
  search: 'Search Engines',
};

const catColors: Record<string, string> = {
  vpn: 'var(--cat-vpn)',
  browser: 'var(--cat-browser)',
  email: 'var(--cat-email)',
  messaging: 'var(--cat-messaging)',
  dns: 'var(--cat-dns)',
  os: 'var(--cat-os)',
  search: 'var(--cat-search)',
};
const catBgs: Record<string, string> = {
  vpn: 'var(--cat-vpn-light)',
  browser: 'var(--cat-browser-light)',
  email: 'var(--cat-email-light)',
  messaging: 'var(--cat-messaging-light)',
  dns: 'var(--cat-dns-light)',
  os: 'var(--cat-os-light)',
  search: 'var(--cat-search-light)',
};

const catColor = catColors[d.category];
const catBg = catBgs[d.category];

function scoreClass(n: number) {
  if (n >= 8) return 'score--high';
  if (n >= 6) return 'score--mid';
  return 'score--low';
}

function scoreColor(n: number) {
  if (n >= 8) return 'var(--clr-score-high)';
  if (n >= 6) return 'var(--clr-score-mid)';
  return 'var(--clr-score-low)';
}

const attrs: { label: string; value: boolean }[] = [
  { label: 'Open-source client applications', value: d.attributes.openSource },
  {
    label: 'Independently audited (published)',
    value: d.attributes.auditedThirdParty,
  },
  { label: 'No-logs policy', value: d.attributes.noLogsPolicy },
  {
    label: 'Anonymous signup — no email required',
    value: d.attributes.anonymousSignup,
  },
  { label: 'End-to-end encrypted', value: d.attributes.e2eEncrypted },
  { label: 'Self-hostable', value: d.attributes.selfHostable },
  { label: 'Mobile client available', value: d.attributes.mobileSupport },
  { label: 'Desktop client available', value: d.attributes.desktopSupport },
];

const reviewDate = new Date(d.lastReviewed).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<Layout title={d.name} description={d.description} activeCategory={d.category}>
  <div class="main-content">
    <div class="breadcrumb">
      <a href="/">Privacy Index</a>
      <span class="breadcrumb__sep">/</span>
      <a href={`/${d.category}`} style={`color: ${catColor};`}
        >{categoryLabels[d.category]}</a
      >
      <span class="breadcrumb__sep">/</span>
      <span>{d.name}</span>
    </div>

    <!-- Tool header -->
    <div
      style="display: flex; align-items: flex-start; gap: 1rem; margin-bottom: 1.75rem; padding-bottom: 1.75rem; border-bottom: 1px solid var(--clr-border);"
    >
      <div
        style="width: 52px; height: 52px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
      >
        <ToolLogo slug={d.slug} name={d.name} category={d.category} size={30} />
      </div>
      <div>
        <div
          style="display: flex; align-items: center; gap: 0.625rem; flex-wrap: wrap; margin-bottom: 0.25rem;"
        >
          <h1
            style="font-size: 1.375rem; font-weight: 700; letter-spacing: -0.025em;"
          >
            {d.name}
          </h1>
          <span class={`pricing-badge pricing-badge--${d.pricing.model}`}
            >{d.pricing.model}</span
          >
        </div>
        <div
          style="display: flex; align-items: center; gap: 1rem; font-size: 0.8125rem; color: var(--clr-muted); flex-wrap: wrap;"
        >
          <a
            href={d.website}
            target="_blank"
            rel="noopener noreferrer"
            style="color: var(--clr-muted); border-bottom: 1px solid var(--clr-border);"
          >
            {d.website.replace('https://', '')} ↗
          </a>
          <span>Reviewed {reviewDate}</span>
          <span
            style={`display: inline-flex; align-items: center; gap: 0.25rem; color: ${catColor};`}
          >
            <CategoryIcon category={d.category} size={11} />
            {categoryLabels[d.category]}
          </span>
        </div>
      </div>
    </div>

    <div class="detail-layout">
      <!-- Main column -->
      <div>
        <!-- Score panel -->
        <div class="score-panel">
          {
            [
              { label: 'Privacy', value: d.scores.privacy },
              { label: 'Security', value: d.scores.security },
              { label: 'Usability', value: d.scores.usability },
            ].map((s) => (
              <div class="score-panel__item">
                <div
                  class="score-panel__value"
                  style={`color: ${scoreColor(s.value)}`}
                >
                  {s.value.toFixed(1)}
                </div>
                <div class="score-panel__label">{s.label}</div>
              </div>
            ))
          }
        </div>

        <div class="detail-section">
          <div class="detail-section__title">Summary</div>
          <p class="detail-section__body">{d.description}</p>
        </div>

        <div class="detail-section">
          <div class="detail-section__title">Analysis</div>
          <p class="detail-section__body">{d.rationale}</p>
        </div>

        <div class="detail-section">
          <div class="detail-section__title">Trust attributes</div>
          <ul class="attr-list">
            {
              attrs.map((attr) => (
                <li class="attr-list__item">
                  <span
                    class={`attr-icon ${attr.value ? 'attr-icon--yes' : 'attr-icon--no'}`}
                  >
                    {attr.value ? '✓' : '–'}
                  </span>
                  <span
                    style={`color: ${attr.value ? 'var(--clr-text)' : 'var(--clr-muted)'}`}
                  >
                    {attr.label}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>

        {
          d.tags.length > 0 && (
            <div class="detail-section">
              <div class="detail-section__title">Technical tags</div>
              <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
                {d.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          )
        }

        {
          alternatives.length > 0 && (
            <div class="detail-section">
              <div class="detail-section__title">
                Alternatives in {categoryLabels[d.category]}
              </div>
              {alternatives.map((alt) => (
                <a href={`/tool/${alt.data.slug}`} class="alt-item">
                  <span class="alt-item__name">{alt.data.name}</span>
                  <span class="alt-item__score">
                    P {alt.data.scores.privacy.toFixed(1)} · S{' '}
                    {alt.data.scores.security.toFixed(1)}
                  </span>
                </a>
              ))}
            </div>
          )
        }
      </div>

      <!-- Sidebar -->
      <aside class="detail-sidebar">
        <div class="sidebar-card">
          <div class="sidebar-card__header">
            <i class="fa-solid fa-chart-bar" aria-hidden="true"></i> Scores
          </div>
          <div class="sidebar-card__body">
            {
              [
                { label: 'Privacy', value: d.scores.privacy },
                { label: 'Security', value: d.scores.security },
                { label: 'Usability', value: d.scores.usability },
              ].map((s) => (
                <div class="sidebar-row">
                  <span class="sidebar-row__key">{s.label}</span>
                  <span class={`score ${scoreClass(s.value)}`}>
                    {s.value.toFixed(1)}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <div class="sidebar-card">
          <div class="sidebar-card__header">
            <i class="fa-solid fa-circle-info" aria-hidden="true"></i> Details
          </div>
          <div class="sidebar-card__body">
            <div class="sidebar-row">
              <span class="sidebar-row__key">Category</span>
              <span class="sidebar-row__val">
                <a href={`/${d.category}`} style={`color: ${catColor};`}
                  >{categoryLabels[d.category]}</a
                >
              </span>
            </div>
            <div class="sidebar-row">
              <span class="sidebar-row__key">Pricing</span>
              <span class="sidebar-row__val">
                <span class={`pricing-badge pricing-badge--${d.pricing.model}`}
                  >{d.pricing.model}</span
                >
              </span>
            </div>
            <div class="sidebar-row">
              <span class="sidebar-row__key">Website</span>
              <span class="sidebar-row__val">
                <a
                  href={d.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  style="font-size: 0.75rem;"
                >
                  {d.website.replace('https://', '')}
                </a>
              </span>
            </div>
            <div class="sidebar-row">
              <span class="sidebar-row__key">Reviewed</span>
              <span class="sidebar-row__val">{reviewDate}</span>
            </div>
          </div>
        </div>

        <div class="sidebar-card">
          <div class="sidebar-card__header">
            <i class="fa-solid fa-tag" aria-hidden="true"></i> Pricing
          </div>
          <div class="sidebar-card__body">
            <p
              style="font-size: 0.8125rem; color: var(--clr-text-secondary); line-height: 1.6; margin: 0;"
            >
              {d.pricing.details}
            </p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</Layout>
