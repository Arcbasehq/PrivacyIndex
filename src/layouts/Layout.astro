    <script>
      const catColors: Record<string, string> = {
        vpn: '#2dd4bf',
        browser: '#38bdf8',
        email: '#f87171',
        messaging: '#4ade80',
        dns: '#fb923c',
        os: '#94a3b8',
        search: '#60a5fa',
      };
      const catBgs: Record<string, string> = {
        vpn: 'rgba(45,212,191,0.12)',
        browser: 'rgba(56,189,248,0.12)',
        email: 'rgba(248,113,113,0.12)',
        messaging: 'rgba(74,222,128,0.12)',
        dns: 'rgba(251,146,60,0.12)',
        os: 'rgba(148,163,184,0.12)',
        search: 'rgba(96,165,250,0.12)',
      };

      type Tool = {
        slug: string;
        name: string;
        category: string;
        description: string;
        tags: string[];
        pricing: string;
        scores: { privacy: number; security: number; usability: number };
      };

      let index: Tool[] = [];
      let activeIdx = -1;

      const input = document.getElementById(
        'global-search',
      ) as HTMLInputElement;
      const dropdown = document.getElementById(
        'search-dropdown',
      ) as HTMLDivElement;
      const overlay = document.getElementById(
        'search-overlay',
      ) as HTMLDivElement;

      async function loadIndex() {
        if (index.length) return;
        try {
          const res = await fetch('/search-index.json');
          index = await res.json();
        } catch {}
      }

      function highlight(text: string, query: string): string {
        if (!query) return text;
        const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        return text.replace(
          new RegExp(`(${escaped})`, 'gi'),
          '<mark>$1</mark>',
        );
      }

      function openDropdown(results: Tool[], query: string) {
        activeIdx = -1;
        if (!results.length) {
          dropdown.innerHTML = `<div class="search-dropdown__empty"><i class="fa-solid fa-circle-xmark" style="margin-right:0.375rem;"></i>No tools found for "${query}"</div>`;
        } else {
          dropdown.innerHTML = results
            .map((t, i) => {
              const initials = t.name
                .split(' ')
                .map((w) => w[0])
                .join('')
                .slice(0, 2)
                .toUpperCase();
              const color = catColors[t.category] ?? '#8b929e';
              const bg = catBgs[t.category] ?? 'rgba(139,146,158,0.12)';
              const logoSrc = `https://logo.clearbit.com/${t.slug === 'torbrowser' ? 'torproject.org' : t.slug === 'adguarddns' ? 'adguard.com' : t.slug === 'bravesearch' ? 'brave.com' : t.slug === 'dnscrypt' ? 'dnscrypt.info' : t.slug === 'libresearch' ? 'libresearch.ca' : t.slug + '.com'}`;
              return `
            <a
              class="search-result"
              href="/tool/${t.slug}"
              data-idx="${i}"
              role="option"
            >
              <div class="search-result__icon" style="background:${bg};color:${color};overflow:hidden;">
                <img src="${logoSrc}" width="20" height="20" style="object-fit:contain;border-radius:3px;" onerror="this.style.display='none';this.nextSibling.style.display='inline';" /><span style="display:none;font-size:0.6875rem;font-weight:800;">${initials}</span>
              </div>
              <div class="search-result__body">
                <div class="search-result__name">${highlight(t.name, query)}</div>
                <div class="search-result__meta">${t.category.toUpperCase()} · ${t.pricing} · ${highlight(t.tags.slice(0, 3).join(', '), query)}</div>
              </div>
              <div class="search-result__score">${t.scores.privacy.toFixed(1)}</div>
            </a>`;
            })
            .join('');
        }
        dropdown.classList.add('search-dropdown--open');
        overlay.classList.add('search-overlay--open');
        input.setAttribute('aria-expanded', 'true');
      }

      function closeDropdown() {
        dropdown.classList.remove('search-dropdown--open');
        overlay.classList.remove('search-overlay--open');
        input.setAttribute('aria-expanded', 'false');
        activeIdx = -1;
      }

      function updateActive(results: HTMLElement[]) {
        results.forEach((el, i) => {
          el.classList.toggle('search-result--active', i === activeIdx);
          if (i === activeIdx) el.scrollIntoView({ block: 'nearest' });
        });
      }

      input.addEventListener('focus', loadIndex);

      input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        if (!q) {
          closeDropdown();
          return;
        }

        const results = index
          .filter(
            (t) =>
              t.name.toLowerCase().includes(q) ||
              t.description.toLowerCase().includes(q) ||
              t.category.includes(q) ||
              t.tags.some((tag) => tag.includes(q)),
          )
          .slice(0, 8);

        openDropdown(results, q);
      });

      input.addEventListener('keydown', (e) => {
        const items = Array.from(
          dropdown.querySelectorAll<HTMLElement>('.search-result'),
        );
        if (!items.length) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIdx = Math.min(activeIdx + 1, items.length - 1);
          updateActive(items);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIdx = Math.max(activeIdx - 1, -1);
          updateActive(items);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIdx >= 0 && items[activeIdx]) {
            (items[activeIdx] as HTMLAnchorElement).click();
          } else if (items[0]) {
            (items[0] as HTMLAnchorElement).click();
          }
        } else if (e.key === 'Escape') {
          closeDropdown();
          input.blur();
        }
      });

      overlay.addEventListener('click', closeDropdown);
    </script>

    <script>
      // Swap header auth buttons based on Clerk session state.
      // Clerk sets a __session cookie when logged in; we also use
      // window.Clerk for a reliable check once the SDK loads.
      function applyAuthState(signedIn: boolean) {
        const signin = document.getElementById('btn-signin');
        const signup = document.getElementById('btn-signup');
        const dash = document.getElementById('btn-dashboard');
        if (!signin || !signup || !dash) return;

        if (signedIn) {
          signin.style.display = 'none';
          signup.style.display = 'none';
          dash.style.display = 'inline-flex';
        } else {
          signin.style.display = '';
          signup.style.display = '';
          dash.style.display = 'none';
        }
      }

      // Fast check via Clerk session cookie (available synchronously)
      const hasSessionCookie = document.cookie
        .split(';')
        .some(
          (c) =>
            c.trim().startsWith('__session=') ||
            c.trim().startsWith('__client_uat='),
        );
      if (hasSessionCookie) applyAuthState(true);

      // Authoritative check once Clerk SDK has loaded
      window.addEventListener('load', () => {
        const poll = setInterval(() => {
          const w = window as any;
          if (w.Clerk?.loaded) {
            clearInterval(poll);
            applyAuthState(!!w.Clerk.user);
            // Keep in sync if user signs out/in without a page reload
            w.Clerk.addListener(({ user }: { user: unknown }) => {
              applyAuthState(!!user);
            });
          }
        }, 50);
        // Give up after 5 s to avoid infinite polling
        setTimeout(() => clearInterval(poll), 5000);
      });
    </script>
  </body>
</html>
