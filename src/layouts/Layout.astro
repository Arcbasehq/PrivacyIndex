---
import '../styles/global.css';
import CategoryIcon from '../components/CategoryIcon.astro';
import { UserButton } from '@clerk/astro/components';

interface Props {
  title?: string;
  description?: string;
  activeCategory?: string;
}

const {
  title = 'Privacy Index',
  description = 'A structured reference for evaluating privacy and security software. Scored on measurable criteria.',
  activeCategory,
} = Astro.props;

const { userId } = Astro.locals.auth?.() ?? {};

const categories = [
  {
    slug: 'vpn',
    label: 'VPN Services',
    color: 'var(--cat)',
    bg: 'var(--cat-vpn-light)',
  },
  {
    slug: 'browser',
    label: 'Web Browsers',
    color: 'var(--cat)',
    bg: 'var(--cat-browser-light)',
  },
  {
    slug: 'email',
    label: 'Email Providers',
    color: 'var(--cat)',
    bg: 'var(--cat-email-light)',
  },
  {
    slug: 'messaging',
    label: 'Messaging Apps',
    color: 'var(--cat)',
    bg: 'var(--cat-messaging-light)',
  },
  {
    slug: 'dns',
    label: 'DNS Resolvers',
    color: 'var(--cat)',
    bg: 'var(--cat-dns-light)',
  },
  {
    slug: 'os',
    label: 'Operating Systems',
    color: 'var(--cat)',
    bg: 'var(--cat-os-light)',
  },
  {
    slug: 'search',
    label: 'Search Engines',
    color: 'var(--cat)',
    bg: 'var(--cat-search-light)',
  },
];

const pageTitle =
  title === 'Privacy Index' ? title : `${title} — Privacy Index`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/logo1.png" type="image/svg+xml" />
    <link
      rel="canonical"
      href={`https://privacyindex.xyz${Astro.url.pathname}`}
    />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Privacy Index" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={`https://privacyindex.xyz${Astro.url.pathname}`}
    />
    <meta property="og:image" content="https://privacyindex.xyz/og.png" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://privacyindex.xyz/og.png" />
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="b4c11e9f-fdf8-4578-bc39-74a86b5fa256"></script>
  </head>
